@model dynamic

<div class="text-center py-5">
    <i class="bi bi-exclamation-triangle display-1 text-danger"></i>
    <h4 class="mt-3 text-danger">Error</h4>
    <p class="text-muted">@(Model?.Message ?? "Ha ocurrido un error. Intenta nuevamente.")</p>
    <button type="button" class="btn btn-primary mt-3" onclick="loadCartContent()">
        <i class="bi bi-arrow-clockwise"></i> Recargar Carrito
    </button>
</div>
