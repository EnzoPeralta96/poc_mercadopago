@using poc_mercadopago.Presentation.ViewModels.CartViewModels
@model CartViewModel

<div id="cart-content">
    @if (Model.Items.Any())
    {
        <div class="cart-items">
            @foreach (var item in Model.Items)
            {
                <div class="cart-item mb-3 pb-3 border-bottom">

                    <div class="d-flex justify-content-between align-items-start">

                        <div class="flex-grow-1">
                            <h6 class="mb-1">@item.ProductName</h6>
                            @if (!string.IsNullOrEmpty(item.ProductDescription))
                            {
                                <small class="text-muted d-block mb-2">@item.ProductDescription</small>
                            }
                            <div class="d-flex align-items-center gap-2">
                                <span class="fw-bold">$@item.UnitPrice.ToString("N2")</span>
                                <span class="text-muted">x @item.Quantity</span>
                            </div>
                        </div>

                        <div class="text-end">
                            <button type="button" class="btn btn-sm btn-outline-danger mb-2" onclick="removeFromCart('@item.ProductId')">
                                <i class="bi bi-trash"></i>
                            </button>
                            <div class="fw-bold">$@item.Subtotal.ToString("N2")</div>
                        </div>
                    </div>

                    <div class="mt-2">
                        <div class="input-group input-group-sm" style="max-width: 150px;">
                            <button class="btn btn-outline-secondary" type="button" onclick="updateCartQuantity('@item.ProductId', @(item.Quantity - 1))">-</button>
                            <input type="number" class="form-control text-center" value="@item.Quantity" min="1" readonly>
                            <button class="btn btn-outline-secondary" type="button" onclick="updateCartQuantity('@item.ProductId', @(item.Quantity + 1))">+</button>
                        </div>
                    </div>
                    
                </div>
            }
        </div>

        <div class="cart-summary mt-3 pt-3 border-top">
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Items:</span>
                <span>@Model.TotalItems</span>
            </div>
            <div class="d-flex justify-content-between mb-3">
                <span class="fw-bold fs-5">Total:</span>
                <span class="fw-bold fs-5">$@Model.Total.ToString("N2")</span>
            </div>

            <div class="d-grid gap-2">
                <button type="button" class="btn btn-primary btn-lg" onclick="proceedToCheckout()">
                    Proceder al Pago
                </button>
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="clearCart()">
                    Vaciar Carrito
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x display-1 text-muted"></i>
            <p class="mt-3 text-muted">Tu carrito está vacío</p>
            <a href="@Url.Action("Index", "Home")" class="btn btn-primary">Ver Productos</a>
        </div>
    }
</div>