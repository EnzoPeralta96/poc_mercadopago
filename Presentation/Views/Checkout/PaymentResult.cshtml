
@using poc_mercadopago.Presentation.ViewModels.CheckoutViewModels
@model PaymentResultViewModel

@{
    ViewData["Title"] = Model.IsSuccess ? "Pago Exitoso" : Model.IsFailure ? "Pago Rechazado" : "Pago Pendiente";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-6 col-md-8">
        @if (Model.IsSuccess)
        {
            <div class="card border-success">
                <div class="card-body text-center">
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                    <h2 class="mt-3 text-success">¡Pago Exitoso!</h2>
                    <p class="text-muted">
                        Tu pago ha sido procesado correctamente. Recibirás un email de confirmación en breve.
                    </p>
                </div>
            </div>
        }
        else if (Model.IsFailure)
        {
            <div class="card border-danger">
                <div class="card-body text-center">
                    <i class="bi bi-x-circle-fill text-danger" style="font-size: 4rem;"></i>
                    <h2 class="mt-3 text-danger">Pago Rechazado</h2>
                    <p class="text-muted">
                        Lo sentimos, tu pago no pudo ser procesado. Por favor, verifica tus datos e intenta nuevamente.
                    </p>
                </div>
            </div>
        }
        else if (Model.IsPending)
        {
            <div class="card border-info">
                <div class="card-body text-center">
                    <i class="bi bi-clock-fill text-info" style="font-size: 4rem;"></i>
                    <h2 class="mt-3 text-info">Pago Pendiente</h2>
                    <p class="text-muted">
                        Tu pago está siendo procesado. Te notificaremos cuando se confirme.
                    </p>
                </div>
            </div>
        }

        <div class="d-grid gap-2 mt-4">
            <a href="/" class="btn btn-primary btn-lg">
                <i class="bi bi-house-fill"></i> Volver al Inicio
            </a>
        </div>
    </div>
</div>
