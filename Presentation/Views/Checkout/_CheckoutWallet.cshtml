@using poc_mercadopago.Presentation.ViewModels.CheckoutViewModels
@model CheckoutProViewModel

<div class="p-3" id="checkout-wallet-content" data-preference-id="@Model.PreferenceId" data-public-key="@Model.PublicKey">
    <div class="text-center mb-4">
        <i class="bi bi-credit-card display-4 text-primary"></i>
        <h5 class="mt-3">Completar Pago</h5>
        <p class="text-muted">Procede con el pago seguro de MercadoPago</p>
    </div>

    <div id="mp-wallet-container-offcanvas"></div>

    <div class="text-center mt-3">
        <small class="text-muted">
            <i class="bi bi-shield-check"></i> Pago seguro con MercadoPago
        </small>
    </div>
</div>
